// Corrected compact mumax3 script.
OutputFormat = OVF2_TEXT

nx := 128
ny := 64
nz := 1
SetGridSize(nx, ny, nz)
SetCellSize(4e-9, 4e-9, 2e-9)
SetGeom(Rect(512e-9, 256e-9))

Msat = 800e3
Aex = 13e-12
alpha = 0.01
Ku1 = pow(2, 5)

m = Uniform(1, 0, 0)
TableAdd(m)
TableAdd(E_total)
TableAutoSave(5e-12)

Relax()
SaveAs(m, "m_relaxed.ovf")

h0 := 1e-3
f := 10e9
B_ext = Vector(0, h0*sin(2*pi*f*t), 0)

Run(2e-9)
SaveAs(m, "m_final.ovf")
TableSave()

